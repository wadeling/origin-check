DATABASE_URL=postgres://origin:origin@localhost:5432/origin_check?sslmode=disable
REDIS_URL=redis://localhost:6379/0
ENCRYPTION_KEY=change-me-to-32-byte-secret-key!!
API_ADDR=:8080
CORS_ORIGIN=http://localhost:3000

# Probe schedule (Go duration format: 15m, 6h, 24h)
PROBE_HEALTH_INTERVAL=15m
PROBE_PERFORMANCE_INTERVAL=24h
PROBE_AUTHENTICITY_INTERVAL=24h
PROBE_HEALTH_ON_STARTUP=true
PROBE_PERFORMANCE_ON_STARTUP=false
PROBE_AUTHENTICITY_ON_STARTUP=false

# Relay API keys (optional for seed)
LIAOBOTS_API_KEY=
LINGYAAI_API_KEY=
ASIAI_API_KEY=
NICEGOAL_API_KEY=
